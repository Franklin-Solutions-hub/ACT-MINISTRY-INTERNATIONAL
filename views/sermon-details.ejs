<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= data.sermon.title %> | ACT Ministry International</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/church-logo.png" type="image/png">
</head>
<body style="background: #fdfdfd;">

  <!-- ====== NAVBAR ====== -->
  <nav class="navbar" id="navbar" style="background: var(--deep-blue); padding: 15px 0;">
    <div class="container">
      <a href="/" class="nav-logo">
        <img src="/images/church-logo.png" alt="ACT Ministry Logo">
        <div class="nav-logo-text">
          ACT Ministry
          <span>Apostolic Core Team Ministry Intl.</span>
        </div>
      </a>
      <div class="nav-links" id="navLinks">
        <a href="/">Home</a>
        <a href="/leadership">Leadership</a>
        <a href="/sermons" class="active-link">Sermons</a>
        <a href="/#contact">Contact</a>
        <a href="<%= data.settings.watch_live_link || 'https://www.youtube.com' %>" target="_blank" rel="noopener" class="nav-cta">
          <i class='bx bx-play-circle'></i> Watch Live
        </a>
      </div>
      <div class="hamburger" id="hamburger"><span></span><span></span><span></span></div>
    </div>
  </nav>

  <main style="padding-top: 100px; padding-bottom: 60px;">
    <div class="container" style="max-width: 1000px;">
      
      <!-- Back Button -->
      <a href="/sermons" style="display: inline-flex; align-items: center; gap: 5px; color: var(--gray); text-decoration: none; font-weight: 500; margin-bottom: 20px; transition: color 0.3s ease;" onmouseover="this.style.color='var(--magenta)'" onmouseout="this.style.color='var(--gray)'">
        <i class='bx bx-left-arrow-alt' style="font-size: 1.2rem;"></i> Back to Library
      </a>

      <!-- Main Player -->
      <div style="width: 100%; background: #000; border-radius: 12px; overflow: hidden; box-shadow: 0 15px 40px rgba(0,0,0,0.15); margin-bottom: 30px; position: relative; aspect-ratio: 16/9;">
        <% if(data.sermon.video_url && data.sermon.video_url.startsWith('/images/')) { %>
          <video src="<%= encodeURI(data.sermon.video_url) %>" controls controlsList="nodownload" style="width: 100%; height: 100%; display: block;" poster="<%= data.sermon.thumbnail_url || '' %>"></video>
        <% } else if(data.sermon.video_url) { %>
          <iframe src="<%= data.sermon.video_url %>" style="width: 100%; height: 100%; border: none;" allowfullscreen></iframe>
        <% } else if(data.sermon.audio_url) { %>
          <div style="width:100%; height:100%; background: url('<%= data.sermon.thumbnail_url || data.settings.hero_banner_url %>') center/cover; position:relative;">
            <div style="position: absolute; inset:0; background: rgba(0,0,0,0.6);"></div>
            <audio src="<%= data.sermon.audio_url %>" controls style="position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); width: 80%;"></audio>
            <i class='bx bx-podcast' style="position: absolute; top:50%; left:50%; transform:translate(-50%, -50%); font-size:6rem; color:rgba(255,255,255,0.8);"></i>
          </div>
        <% } else { %>
          <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; flex-direction: column;">
            <i class='bx bx-video-off' style="font-size: 4rem; margin-bottom: 10px;"></i>
            <p>Media Unavailable</p>
          </div>
        <% } %>
      </div>

      <!-- Sermon Info -->
      <div style="background: white; padding: 40px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
        <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; gap: 20px;">
          <div>
            <div style="display:flex; gap: 10px; margin-bottom: 15px; align-items: center;">
              <span style="background: rgba(214, 51, 132, 0.1); color: var(--magenta); padding: 5px 12px; border-radius: 20px; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;"><%= data.sermon.category || 'General' %></span>
              <span style="color: var(--gray); font-size: 0.95rem; font-weight: 500;"><i class='bx bx-calendar'></i> <%= data.sermon.date_preached ? new Date(data.sermon.date_preached).toLocaleDateString('en-US', {month: 'long', day: 'numeric', year: 'numeric'}) : 'Recently Added' %></span>
            </div>
            <h1 style="font-family: var(--font-heading); font-size: clamp(1.8rem, 4vw, 2.5rem); color: var(--deep-blue); margin-bottom: 10px; line-height: 1.2;"><%= data.sermon.title %></h1>
            <p style="color: var(--dark); font-weight: 600; font-size: 1.1rem;"><i class='bx bx-user' style="color: var(--magenta); margin-right: 5px;"></i> <%= data.sermon.preacher || 'Prophet Samuel Eghan Gorman' %></p>
          </div>

          <!-- Share Buttons -->
          <div style="display: flex; gap: 10px;">
            <a href="https://api.whatsapp.com/send?text=Watch this powerful message: *<%= data.sermon.title %>* - https://actministrychurch.com/sermons/<%= data.sermon.id %>" target="_blank" style="width: 45px; height: 45px; border-radius: 50%; background: #25D366; color: white; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; transition: transform 0.3s ease;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'"><i class='bx bxl-whatsapp'></i></a>
            <a href="https://www.facebook.com/sharer/sharer.php?u=https://actministrychurch.com/sermons/<%= data.sermon.id %>" target="_blank" style="width: 45px; height: 45px; border-radius: 50%; background: #1877F2; color: white; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; transition: transform 0.3s ease;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'"><i class='bx bxl-facebook'></i></a>
          </div>
        </div>

        <hr style="border: none; border-top: 1px solid #eaeaea; margin: 30px 0;">

        <% if(data.sermon.scripture) { %>
          <div style="background: rgba(30,30,100,0.03); padding: 20px; border-left: 4px solid var(--deep-blue); border-radius: 0 8px 8px 0; margin-bottom: 30px;">
            <p style="margin: 0; color: var(--deep-blue); font-weight: 600; font-size: 1.05rem;"><i class='bx bx-book-open'></i> Scripture Reference: <span style="font-weight: 400;"><%= data.sermon.scripture %></span></p>
          </div>
        <% } %>

        <div class="sermon-description" style="line-height: 1.8; color: #444; font-size: 1.05rem; white-space: pre-wrap;"><%= data.sermon.description %></div>

      </div>
    </div>
  </main>

  <!-- ====== FOOTER ====== -->
  <footer class="footer" id="footer">
    <div class="footer-main">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <div class="footer-logo">
              <img src="/images/church-logo.png" alt="Logo">
              <div class="footer-logo-text">ACT Ministry<span>Apostolic Core Team</span></div>
            </div>
            <p class="footer-tagline">"Come and Experience the overflow of God's Power"</p>
          </div>
          <div class="footer-col">
            <h4>Quick Links</h4>
            <ul><li><a href="/">Home</a></li><li><a href="/leadership">Leadership</a></li><li><a href="/sermons">Sermons</a></li></ul>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <ul>
              <li><a href="tel:<%= data.settings.contact_phone1 %>"><%= data.settings.contact_phone1 %></a></li>
              <li><a href="mailto:<%= data.settings.contact_email %>"><%= data.settings.contact_email %></a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <p>&copy; 2025 ACT Ministry International Church. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/js/script.js"></script>
</body>
</html>
